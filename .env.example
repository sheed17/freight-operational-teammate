# Copy to .env and fill in. The demo reads these via python-dotenv.

# --- Vision extraction provider ---
# Which provider to use for vision extraction: "anthropic" or "openai"
EXTRACTION_PROVIDER=anthropic

# Anthropic (default). Vision-capable model.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI (alternative — for the empirical Claude-vs-GPT bake-off in the spec).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
